#!/usr/bin/env bash
set -euo pipefail  # exit on error, abort on unset variables, propagate pipe failures

source "$(dirname "$0")/common.sh"

mkdir -p "$(pwd)/.claude"
[[ -f "$(pwd)/.claude.json" ]] || echo '{}' > "$(pwd)/.claude.json"

docker run -it --rm \
  --network host \
  --user "$(id -u):$(id -g)" \
  -e HOME=/home/node \
  -v /etc/passwd:/etc/passwd:ro \
  -v /etc/group:/etc/group:ro \
  -e ANTHROPIC_BASE_URL="$OLLAMA_URL" \
  -e ANTHROPIC_AUTH_TOKEN="$OLLAMA_AUTH_TOKEN" \
  -e ANTHROPIC_DEFAULT_OPUS_MODEL="$MODEL" \
  -e ANTHROPIC_DEFAULT_SONNET_MODEL="$MODEL" \
  -e ANTHROPIC_DEFAULT_HAIKU_MODEL="$MODEL" \
  -v "$(pwd)":/workspace \
  -v "$(pwd)/.claude":/home/node/.claude \
  -v "$(pwd)/.claude.json":/home/node/.claude.json \
  "$IMAGE_NAME" \
  --dangerously-skip-permissions \
  "$@"
